{
  "$schema": "https://opencode.ai/config.json",
  // Optional local provider example. Artemis core does not require Ollama.
  // Replace "your-local-model" with any Ollama-served model, for example a
  // local Kimi, DeepSeek, Qwen, or other OpenAI-compatible model name.
  "model": "ollama/your-local-model",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "your-local-model": {
          "name": "Your local Ollama model",
          "limit": {
            "context": 131072,
            "output": 32768
          }
        }
      }
    }
  }
}
