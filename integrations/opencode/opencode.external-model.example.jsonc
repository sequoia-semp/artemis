{
  "$schema": "https://opencode.ai/config.json",
  // Optional external harness example. Configure provider/model according to your OpenCode installation.
  // Keep Artemis domain behavior in repo files and deterministic pga commands.
  "permission": {
    "edit": "ask",
    "bash": {
      "python -m pytest -q": "allow",
      "pga validate-registries": "allow",
      "pga validate-work-items": "allow",
      "pga work-context*": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git push*": "ask",
      "git tag*": "ask",
      "*": "ask"
    }
  }
}
