# Copy to local/.env and keep real values out of git.

# Optional local OpenAI-compatible endpoint served by Ollama.
OLLAMA_API_KEY=ollama
ARTEMIS_OPENAI_COMPATIBLE_BASE_URL=http://localhost:11434/v1
ARTEMIS_OPENAI_COMPATIBLE_MODEL=qwen3-coder:30b

# Optional vendor/API credentials. Use real secrets only in local/.env or your shell.
ARTEMIS_PJM_API_KEY=
ARTEMIS_PJM_API_BASE_URL=https://api.pjm.com/api/v1
ARTEMIS_PJM_ACCOUNT_CLASS=non_member
# Optional override for private operational runs; leave unset to use the account class policy.
ARTEMIS_PJM_MAX_CONNECTIONS_PER_MINUTE=
ARTEMIS_RUN_LIVE_PJM_TESTS=0
ARTEMIS_VENDOR_API_KEY=
ARTEMIS_ICE_API_KEY=

# Optional local or mounted file-source roots for marks, positions, trades, and internal source drops.
ARTEMIS_MARKS_ROOT=/absolute/path/to/marks
ARTEMIS_POSITIONS_ROOT=/absolute/path/to/positions
ARTEMIS_TRADES_ROOT=/absolute/path/to/trades
ARTEMIS_INTERNAL_DB_ROOT=/absolute/path/to/internal_sources
