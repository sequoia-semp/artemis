{
  "$schema": "https://opencode.ai/config.json",
  // Compatibility shim only. Artemis authority is AGENTS.md plus artemis.yaml.
  // Active backend descriptor: integrations/coding_backends/opencode.yaml.
  // Model/provider examples live under integrations/coding_backends/opencode/.
  "permission": {
    "edit": "ask",
    "bash": {
      "python -m pytest -q": "allow",
      "make validate": "allow",
      "artemis capabilities": "allow",
      "artemis config validate": "allow",
      "artemis dev context*": "allow",
      "pga validate-registries": "allow",
      "pga validate-work-items": "allow",
      "pga validate-kb": "allow",
      "pga work-context*": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git push*": "ask",
      "git tag*": "ask",
      "pga build-state-pack*": "ask",
      "pga normalize-*": "ask",
      "pga run-*": "ask",
      "*": "ask"
    },
    "skill": {
      "*": "allow"
    }
  }
}
