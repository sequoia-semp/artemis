{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ArtemisConfig",
  "type": "object",
  "additionalProperties": true,
  "not": {"required": ["profiles"]},
  "properties": {
    "version": {"type": "string"},
    "name": {"const": "artemis"},
    "package": {"type": "string"},
    "mission": {
      "type": "object",
      "required": ["type", "description"],
      "properties": {
        "type": {"type": "string"},
        "description": {"type": "string"}
      }
    },
    "authority": {
      "type": "object",
      "required": ["root_contract", "deterministic_core", "canonical_domain", "change_policy"],
      "properties": {
        "root_contract": {"type": "string"},
        "deterministic_core": {"type": "array", "items": {"type": "string"}},
        "canonical_domain": {"type": "array", "items": {"type": "string"}},
        "change_policy": {"type": "string"}
      }
    },
    "modes": {
      "type": "object",
      "required": ["analyst", "development"],
      "properties": {
        "analyst": {"$ref": "#/$defs/mode"},
        "development": {"$ref": "#/$defs/mode"}
      }
    },
    "roles": {"type": "object"},
    "providers": {"type": "object"},
    "runtime": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "env_files": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "file_sources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "marks_root_env": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]*$"},
        "positions_root_env": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]*$"},
        "trades_root_env": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]*$"},
        "internal_db_root_env": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]*$"}
      }
    },
    "tools": {
      "type": "object",
      "required": ["registry", "permissions"],
      "properties": {
        "registry": {"type": "string"},
        "permissions": {"type": "string"}
      }
    },
    "skills": {"type": "object"},
    "views": {"type": "object"},
    "data_sources": {"type": "object"},
    "policies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cache", "forecast_retention", "source", "risk"],
      "properties": {
        "cache": {"type": "string"},
        "forecast_retention": {"type": "string"},
        "source": {"type": "string"},
        "risk": {"type": "string"}
      }
    },
    "release": {"type": "object"}
  },
  "required": [
    "version",
    "name",
    "package",
    "mission",
    "authority",
    "modes",
    "roles",
    "providers",
    "file_sources",
    "tools",
    "skills",
    "views",
    "data_sources",
    "policies",
    "release"
  ],
  "$defs": {
    "mode": {
      "type": "object",
      "required": ["description", "can_modify_repo", "default_tools"],
      "properties": {
        "description": {"type": "string"},
        "can_modify_repo": {"type": "boolean"},
        "can_write_workspace_outputs": {"type": "boolean"},
        "can_update_canonical_kb": {"type": "boolean"},
        "requires_ticket": {"type": "boolean"},
        "requires_validation": {"type": "boolean"},
        "default_tools": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
