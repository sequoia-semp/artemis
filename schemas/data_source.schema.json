{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DataSourceRegistry",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {"type": "string"},
    "data_sources": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "required", "credentials", "supported_contracts"],
        "properties": {
          "kind": {"enum": ["file", "vendor_api", "iso_api", "ice_exchange"]},
          "required": {"type": "boolean"},
          "credentials": {
            "oneOf": [
              {"const": "none"},
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["mode", "required_env"],
                "properties": {
                  "mode": {"const": "env"},
                  "required_env": {
                    "type": "array",
                    "items": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]*$"}
                  }
                }
              }
            ]
          },
          "supported_contracts": {"type": "array", "items": {"type": "string"}, "minItems": 1}
        }
      }
    }
  },
  "required": ["version", "data_sources"]
}
