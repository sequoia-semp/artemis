{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExchangeContract",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "contract_id": {"type": "string"},
    "source_class": {"const": "OFFICIAL_EXCHANGE_SPEC"},
    "exchange": {"type": "string"},
    "clearing_venue": {"type": "string"},
    "mic_code": {"type": "string"},
    "product_guide_id": {"type": "string"},
    "product_name": {"type": "string"},
    "contract_symbol": {"type": "string"},
    "commodity": {"enum": ["power", "gas"]},
    "location_id": {"type": "string"},
    "market_run": {"enum": ["DA", "RT"]},
    "price_component": {"const": "FULL_LMP"},
    "shape": {"enum": ["PEAK", "OFFPEAK", "ATC"]},
    "index_family": {
      "enum": ["GDD", "LD1", "IFERC", "BASIS_TO_LD1", "GDD_INDEX_TO_IFERC", "GDD_SWING", "CUSTOM"]
    },
    "quote_unit": {"type": "string"},
    "settlement_method": {"type": "string"},
    "contract_size": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "unit"],
      "properties": {
        "value": {"type": "number"},
        "unit": {"type": "string"}
      }
    },
    "contract_period": {"enum": ["daily", "monthly"]},
    "listing_cycle": {"type": "string"},
    "last_trading_day_rule": {"type": "string"},
    "final_settlement": {"type": "string"},
    "reference_price": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "publisher",
        "published_heading",
        "pricing_date_rule",
        "specified_price_rule",
        "pricing_calendar",
        "delivery_date_rule"
      ],
      "properties": {
        "id": {"type": "string"},
        "publisher": {"type": "string"},
        "published_heading": {"type": "string"},
        "pricing_date_rule": {"type": "string"},
        "specified_price_rule": {"type": "string"},
        "pricing_calendar": {"type": "string"},
        "delivery_date_rule": {"type": "string"}
      }
    },
    "reference_prices": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "leg",
          "id",
          "publisher",
          "published_heading",
          "pricing_date_rule",
          "specified_price_rule",
          "pricing_calendar",
          "delivery_date_rule"
        ],
        "properties": {
          "leg": {"type": "string"},
          "id": {"type": "string"},
          "publisher": {"type": "string"},
          "published_heading": {"type": "string"},
          "pricing_date_rule": {"type": "string"},
          "specified_price_rule": {"type": "string"},
          "pricing_calendar": {"type": "string"},
          "delivery_date_rule": {"type": "string"}
        }
      }
    },
    "settlement_formula": {
      "type": "object",
      "additionalProperties": false,
      "required": ["formula_type", "description", "legs"],
      "properties": {
        "formula_type": {"enum": ["REFERENCE_PRICE_A", "REFERENCE_PRICE_A_MINUS_B", "AVERAGE_REFERENCE_PRICE_A_MINUS_B"]},
        "description": {"type": "string"},
        "legs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["leg", "operation", "index_family"],
            "properties": {
              "leg": {"type": "string"},
              "operation": {"enum": ["add", "subtract"]},
              "index_family": {
                "enum": ["GDD", "LD1", "IFERC", "BASIS_TO_LD1", "GDD_INDEX_TO_IFERC", "GDD_SWING", "CUSTOM"]
              }
            }
          }
        }
      }
    },
    "source_documents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["authority", "url", "notes"],
        "properties": {
          "authority": {"type": "string"},
          "url": {"type": "string"},
          "notes": {"type": "string"}
        }
      }
    },
    "verification_status": {"enum": ["official_exchange_spec_verified", "candidate"]},
    "status": {"enum": ["approved_core", "candidate"]}
  },
  "required": [
    "contract_id",
    "source_class",
    "exchange",
    "product_guide_id",
    "product_name",
    "contract_symbol",
    "commodity",
    "location_id",
    "quote_unit",
    "settlement_method",
    "contract_size",
    "contract_period",
    "final_settlement",
    "source_documents",
    "verification_status",
    "status"
  ],
  "anyOf": [
    {"required": ["reference_price"]},
    {"required": ["reference_prices"]}
  ],
  "allOf": [
    {
      "if": {"properties": {"commodity": {"const": "power"}}, "required": ["commodity"]},
      "then": {"required": ["market_run", "price_component", "shape", "reference_price"]}
    },
    {
      "if": {"properties": {"commodity": {"const": "gas"}}, "required": ["commodity"]},
      "then": {"required": ["index_family"]}
    }
  ]
}
