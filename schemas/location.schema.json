{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Location",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "location_id": {
      "type": "string"
    },
    "display_name": {
      "type": "string"
    },
    "commodity": {
      "enum": [
        "power",
        "gas"
      ]
    },
    "group_1": {
      "type": "string"
    },
    "group_2": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string"
    }
  },
  "required": [
    "location_id",
    "display_name",
    "commodity"
  ]
}
