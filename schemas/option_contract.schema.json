{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OptionContract",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "option_contract_id": {"type": "string"},
    "source_class": {"const": "OFFICIAL_EXCHANGE_SPEC"},
    "exchange": {"type": "string"},
    "clearing_venue": {"type": "string"},
    "mic_code": {"type": "string"},
    "product_guide_id": {"type": "string"},
    "product_name": {"type": "string"},
    "contract_symbol": {"type": "string"},
    "commodity": {"enum": ["power", "gas"]},
    "location_id": {"type": "string"},
    "market_run": {"enum": ["DA", "RT"]},
    "price_component": {"const": "FULL_LMP"},
    "shape": {"enum": ["PEAK", "OFFPEAK", "ATC"]},
    "underlying_contract_id": {"type": "string"},
    "underlying_contract_symbol": {"type": "string"},
    "underlying_index_id": {"type": "string"},
    "settlement_method": {"type": "string"},
    "contract_size": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "unit"],
      "properties": {
        "value": {"type": "number"},
        "unit": {"type": "string"},
        "description": {"type": "string"}
      }
    },
    "contract_period": {"enum": ["monthly", "annual_strip"]},
    "premium_quote_unit": {"type": "string"},
    "strike_unit": {"type": "string"},
    "currency": {"type": "string"},
    "minimum_price_fluctuation": {"type": "string"},
    "listing_cycle": {"type": "string"},
    "last_trading_day_rule": {"type": "string"},
    "option_style": {"enum": ["American", "European"]},
    "exercise_method": {"type": "string"},
    "exercise_procedure": {"type": "string"},
    "exercise_day_rule": {"type": "string"},
    "automatic_exercise": {"type": "string"},
    "valuation_model": {"const": "Black76"},
    "model_scope": {"type": "string"},
    "reference_price": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "publisher",
        "description",
        "pricing_date_rule",
        "specified_price_rule",
        "pricing_calendar",
        "delivery_date_rule"
      ],
      "properties": {
        "id": {"type": "string"},
        "publisher": {"type": "string"},
        "description": {"type": "string"},
        "pricing_date_rule": {"type": "string"},
        "specified_price_rule": {"type": "string"},
        "pricing_calendar": {"type": "string"},
        "delivery_date_rule": {"type": "string"}
      }
    },
    "strike_price_listing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimum_strikes", "standard_increment", "user_defined_increment"],
      "properties": {
        "minimum_strikes": {"type": "integer"},
        "standard_increment": {"type": "string"},
        "user_defined_increment": {"type": "string"},
        "notes": {"type": "string"}
      }
    },
    "source_documents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["authority", "url", "notes"],
        "properties": {
          "authority": {"type": "string"},
          "url": {"type": "string"},
          "notes": {"type": "string"}
        }
      }
    },
    "verification_status": {"enum": ["official_exchange_spec_verified", "candidate"]},
    "status": {"enum": ["approved_core", "candidate"]}
  },
  "required": [
    "option_contract_id",
    "source_class",
    "exchange",
    "product_guide_id",
    "product_name",
    "contract_symbol",
    "commodity",
    "location_id",
    "underlying_index_id",
    "settlement_method",
    "contract_size",
    "contract_period",
    "premium_quote_unit",
    "strike_unit",
    "currency",
    "last_trading_day_rule",
    "option_style",
    "exercise_method",
    "valuation_model",
    "model_scope",
    "reference_price",
    "strike_price_listing",
    "source_documents",
    "verification_status",
    "status"
  ],
  "allOf": [
    {
      "if": {"properties": {"commodity": {"const": "power"}}, "required": ["commodity"]},
      "then": {"required": ["market_run", "price_component", "shape", "underlying_contract_id"]}
    },
    {
      "if": {"properties": {"commodity": {"const": "gas"}}, "required": ["commodity"]},
      "then": {"required": ["underlying_contract_symbol"]}
    }
  ]
}
