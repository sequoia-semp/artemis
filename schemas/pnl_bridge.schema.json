{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PnLBridge",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "run_id": {
      "type": "string"
    },
    "current_as_of": {
      "type": "string"
    },
    "prior_as_of": {
      "type": "string"
    },
    "position_change_effect": {
      "type": "number"
    },
    "price_move_effect": {
      "type": "number"
    },
    "basis_move_effect": {
      "type": "number"
    },
    "strip_weight_effect": {
      "type": "number"
    },
    "atc_component_effect": {
      "type": "number"
    },
    "mark_adjustment_effect": {
      "type": "number"
    },
    "unexplained_residual": {
      "type": "number"
    },
    "bridge_sums": {
      "type": "boolean"
    },
    "exceptions": {
      "type": "array"
    }
  },
  "required": [
    "run_id",
    "current_as_of",
    "prior_as_of"
  ]
}
