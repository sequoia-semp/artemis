{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PowerGenerationMixFeed",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "feed_id",
    "display_name",
    "source",
    "market",
    "commodity",
    "source_system",
    "product_type",
    "data_miner_feed",
    "granularity",
    "value_unit",
    "time_columns",
    "fuel_columns",
    "value_columns",
    "source_documents",
    "verification_status",
    "status"
  ],
  "properties": {
    "feed_id": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
    "display_name": {"type": "string"},
    "source": {"const": "PJM Data Miner"},
    "market": {"const": "PJM"},
    "commodity": {"const": "power"},
    "source_system": {"enum": ["iso_rto_api"]},
    "product_type": {"enum": ["generation_mix"]},
    "data_miner_feed": {"type": "string"},
    "granularity": {"enum": ["hourly"]},
    "value_unit": {"const": "MW"},
    "time_columns": {
      "type": "object",
      "additionalProperties": false,
      "required": ["delivery_start_utc", "delivery_start_ept"],
      "properties": {
        "delivery_start_utc": {"type": "string"},
        "delivery_start_ept": {"type": "string"}
      }
    },
    "fuel_columns": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fuel_type", "is_renewable"],
      "properties": {
        "fuel_type": {"type": "string"},
        "is_renewable": {"type": "string"}
      }
    },
    "value_columns": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mw"],
      "properties": {
        "mw": {"type": "string"},
        "fuel_percentage_of_total": {"type": "string"}
      }
    },
    "source_documents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["authority", "url", "notes"],
        "properties": {
          "authority": {"type": "string"},
          "url": {"type": "string"},
          "notes": {"type": "string"}
        }
      },
      "minItems": 1
    },
    "verification_status": {"enum": ["candidate", "official_pjm_documented"]},
    "status": {"enum": ["candidate", "approved_core"]}
  }
}
