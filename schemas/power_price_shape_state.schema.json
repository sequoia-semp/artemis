{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PowerPriceShapeState",
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id", "as_of", "source_points", "price_surface_points", "gaps", "lineage"],
  "properties": {
    "run_id": {"type": "string"},
    "as_of": {"type": "string"},
    "source_points": {
      "type": "array",
      "items": {"type": "object"}
    },
    "price_surface_points": {
      "type": "array",
      "items": {"type": "object"}
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rule_id", "location_id", "market_run", "date", "reason"],
        "properties": {
          "rule_id": {"type": "string"},
          "location_id": {"type": "string"},
          "market_run": {"type": "string"},
          "date": {"type": "string"},
          "reason": {"type": "string"},
          "expected_hours": {"type": "integer"},
          "observed_hours": {"type": "integer"}
        }
      }
    },
    "lineage": {"type": "object"}
  }
}
