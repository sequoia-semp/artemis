{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PowerSystemRawFetchManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_id",
    "operator_id",
    "source_system",
    "source_surface",
    "source_name",
    "data_environment",
    "contract",
    "registry_feed_id",
    "source_feed",
    "request_id",
    "request_kind",
    "query_plan_id",
    "row_count",
    "query_parameter_keys",
    "query_fields",
    "raw_records_sha256",
    "contains_raw_records",
    "contains_secret_values"
  ],
  "properties": {
    "manifest_id": {"type": "string", "minLength": 1},
    "operator_id": {"type": "string", "minLength": 1},
    "source_system": {"type": "string", "minLength": 1},
    "source_surface": {"type": "string", "minLength": 1},
    "source_name": {"type": "string", "minLength": 1},
    "data_environment": {"type": "string", "minLength": 1},
    "contract": {"type": "string", "minLength": 1},
    "registry_feed_id": {"type": "string", "minLength": 1},
    "source_feed": {"type": "string", "minLength": 1},
    "request_id": {"type": "string", "minLength": 1},
    "request_kind": {"type": "string", "minLength": 1},
    "query_plan_id": {"type": "string", "minLength": 1},
    "window_start": {"type": ["string", "null"]},
    "window_end": {"type": ["string", "null"]},
    "pnode_id": {"type": ["integer", "null"]},
    "row_count": {"type": "integer", "minimum": 0},
    "total_rows": {"type": ["integer", "null"], "minimum": 0},
    "page_count": {"type": ["integer", "null"], "minimum": 0},
    "max_pages": {"type": ["integer", "null"], "minimum": 1},
    "truncated_by_max_pages": {"type": "boolean"},
    "query_parameter_keys": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "query_fields": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "raw_records_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "contains_raw_records": {"const": false},
    "contains_secret_values": {"const": false}
  }
}
