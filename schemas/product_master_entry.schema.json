{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProductMasterEntry",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "product_id": {"type": "string"},
    "commodity": {"enum": ["power", "gas"]},
    "location_id": {"type": "string"},
    "market_run": {"type": "string"},
    "price_component": {"type": "string"},
    "shape": {"type": "string"},
    "index_family": {"type": "string"},
    "status": {"type": "string"},
    "official_spec_status": {"type": "string"}
  },
  "required": ["product_id", "commodity", "location_id", "status"]
}
