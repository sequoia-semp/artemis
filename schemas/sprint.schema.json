{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    {"$ref": "work_item.schema.json"},
    {
      "type": "object",
      "properties": {
        "type": {"const": "sprint"},
        "epic": {"type": "string"},
        "tickets": {"type": "array", "items": {"type": "string"}},
        "acceptance_criteria": {"type": "array", "items": {"type": "string"}}
      },
      "required": ["epic", "tickets", "acceptance_criteria"]
    }
  ]
}
