{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ToolRegistry",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {"type": "string"},
    "tools": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "risk", "modes", "adapter", "input_contract", "output_contract", "lineage", "authority", "deterministic_service"],
        "properties": {
          "command": {"type": "string"},
          "risk": {"type": "string"},
          "modes": {
            "type": "array",
            "items": {"enum": ["analyst", "development"]},
            "minItems": 1
          },
          "adapter": {"enum": ["cli", "python", "mcp", "external", "manual"]},
          "input_contract": {
            "type": "object",
            "required": ["type"],
            "additionalProperties": true,
            "properties": {
              "type": {"type": "string"},
              "required": {"type": "array", "items": {"type": "string"}}
            }
          },
          "output_contract": {
            "type": "object",
            "required": ["type"],
            "additionalProperties": true,
            "properties": {
              "type": {"type": "string"}
            }
          },
          "lineage": {
            "type": "object",
            "required": ["records"],
            "additionalProperties": true,
            "properties": {
              "records": {"type": "array", "items": {"type": "string"}}
            }
          },
          "authority": {
            "enum": [
              "deterministic_service",
              "compatibility_alias",
              "candidate_only",
              "human_review_required"
            ]
          },
          "deterministic_service": {"type": "boolean"}
        }
      }
    }
  },
  "required": ["version", "tools"]
}
